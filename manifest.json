{
  "manifest_version": 3,
  "name": "LPU Auto Login",
  "version": "2.5",
  "description": "Automated high-speed logins for LPU Gateway, MyClass, and OAS with a premium glassmorphic UI and real-time network monitoring.",
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://internet.lpu.in/*",
        "*://10.10.0.1/*",
        "*://myaccountinternet.lpu.in/*",
        "*://myclass.lpu.in/*",
        "*://oas.lpu.in/*",
        "*://lovelyprofessionaluniversity.codetantra.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
